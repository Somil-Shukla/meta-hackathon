# Copy to .env and fill in your values

# ── Shared fallbacks ──────────────────────────────────────────────────────────
# Used by both agents when per-agent vars below are not set.
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=your_hf_token_here

# ── Per-agent model configuration ────────────────────────────────────────────
# Each agent (defender / fraudster) can use a completely different model,
# API endpoint, and API key.  If a per-agent var is absent, the shared
# fallback above is used automatically.
#
# Example: swap in your fine-tuned GRPO checkpoints after training.
#
DEFENDER_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
DEFENDER_API_BASE_URL=https://router.huggingface.co/v1
DEFENDER_API_KEY=your_hf_token_here

FRAUDSTER_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
FRAUDSTER_API_BASE_URL=https://router.huggingface.co/v1
FRAUDSTER_API_KEY=your_hf_token_here

# ── Server ────────────────────────────────────────────────────────────────────
# Environment server URL (for inference.py client)
ENV_URL=http://localhost:8000

# Server port (for server/app.py)
PORT=8000
